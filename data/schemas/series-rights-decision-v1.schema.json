{
  "$defs": {
    "AttributionField": {
      "description": "Structured source details that must accompany redistributed statistics.",
      "enum": [
        "publisher",
        "original_producer",
        "statistic_name",
        "survey_name",
        "table_name",
        "authoring_date",
        "reference_date",
        "retrieval_date",
        "source_url"
      ],
      "title": "AttributionField",
      "type": "string"
    },
    "AttributionRequirement": {
      "additionalProperties": false,
      "description": "Structured attribution fields plus a mechanically checkable template.",
      "properties": {
        "fields": {
          "items": {
            "$ref": "#/$defs/AttributionField"
          },
          "minItems": 1,
          "title": "Fields",
          "type": "array"
        },
        "template": {
          "maxLength": 10000,
          "minLength": 1,
          "title": "Template",
          "type": "string"
        }
      },
      "required": [
        "fields",
        "template"
      ],
      "title": "AttributionRequirement",
      "type": "object"
    },
    "ContentClass": {
      "description": "Publisher category that selects the applicable branch of a use guide.",
      "enum": [
        "ecos_bok_authored",
        "ecos_other_authored",
        "kosis_domestic_statistics",
        "kosis_easy_view_statistics",
        "kosis_international_statistics",
        "kosis_north_korea_statistics",
        "kosis_publication",
        "oecd_data",
        "other_official_data"
      ],
      "title": "ContentClass",
      "type": "string"
    },
    "EvidenceClaim": {
      "description": "Facts an evidence record explicitly asserts.",
      "enum": [
        "rights_terms",
        "series_scope",
        "original_producer",
        "title_frequency",
        "content_category"
      ],
      "title": "EvidenceClaim",
      "type": "string"
    },
    "EvidenceObservation": {
      "additionalProperties": false,
      "description": "Structured facts observed at one official evidence URL.",
      "properties": {
        "frequency": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frequency"
        },
        "item_id": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._@:/-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Item Id"
        },
        "item_title": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Item Title"
        },
        "kosis_content_category": {
          "anyOf": [
            {
              "$ref": "#/$defs/KosisContentCategory"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mapping_title": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mapping Title"
        },
        "original_producer": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Original Producer"
        },
        "source_system": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSystem"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "table_id": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._@:/-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Table Id"
        },
        "table_title": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Table Title"
        }
      },
      "title": "EvidenceObservation",
      "type": "object"
    },
    "KosisContentCategory": {
      "description": "KOSIS use-guide categories with materially different redistribution terms.",
      "enum": [
        "domestic_statistics",
        "easy_view_statistics",
        "international_statistics",
        "north_korea_statistics",
        "publication"
      ],
      "title": "KosisContentCategory",
      "type": "string"
    },
    "OperationRule": {
      "additionalProperties": false,
      "description": "One operation and its exact status under the cited rights instrument.",
      "properties": {
        "notes": {
          "anyOf": [
            {
              "maxLength": 10000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "operation": {
          "$ref": "#/$defs/RightsOperation"
        },
        "status": {
          "$ref": "#/$defs/OperationStatus"
        }
      },
      "required": [
        "operation",
        "status"
      ],
      "title": "OperationRule",
      "type": "object"
    },
    "OperationStatus": {
      "description": "The exact legal status assigned to one operation by the instrument.",
      "enum": [
        "permitted",
        "prohibited",
        "requires_additional_approval",
        "not_expressly_granted"
      ],
      "title": "OperationStatus",
      "type": "string"
    },
    "ProducerMappingBasis": {
      "description": "How an exact series was mapped to its producer or content category.",
      "enum": [
        "direct_source_metadata",
        "owner_approved_official_cross_source_title_frequency_mapping",
        "official_publisher_documentation",
        "official_content_category",
        "unresolved"
      ],
      "title": "ProducerMappingBasis",
      "type": "string"
    },
    "RedistributionStatus": {
      "description": "What may be published from a retrieved source snapshot.",
      "enum": [
        "allowed",
        "metadata_only",
        "restricted",
        "unknown"
      ],
      "title": "RedistributionStatus",
      "type": "string"
    },
    "RightsEvidence": {
      "additionalProperties": false,
      "description": "One official URL and the structured claims observed there.",
      "properties": {
        "accessed_on": {
          "format": "date",
          "title": "Accessed On",
          "type": "string"
        },
        "assertion": {
          "maxLength": 10000,
          "minLength": 1,
          "title": "Assertion",
          "type": "string"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/EvidenceClaim"
          },
          "minItems": 1,
          "title": "Claims",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/RightsEvidenceKind"
        },
        "observed": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceObservation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "official_url": {
          "format": "uri",
          "minLength": 1,
          "title": "Official Url",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "official_url",
        "accessed_on",
        "claims",
        "assertion"
      ],
      "title": "RightsEvidence",
      "type": "object"
    },
    "RightsEvidenceKind": {
      "description": "Official evidence types supporting producer/category and rights mappings.",
      "enum": [
        "source_metadata",
        "publisher_use_guide",
        "official_cross_source_catalog",
        "official_publisher_release",
        "dataset_terms",
        "producer_specific_terms"
      ],
      "title": "RightsEvidenceKind",
      "type": "string"
    },
    "RightsOperation": {
      "description": "Operations that an official rights instrument may permit or prohibit.",
      "enum": [
        "use",
        "process",
        "redistribute",
        "commercial_use",
        "noncommercial_use",
        "sell_unchanged",
        "distort",
        "reidentify"
      ],
      "title": "RightsOperation",
      "type": "string"
    },
    "SourceSystem": {
      "description": "Official systems for which the rights contract has an explicit policy branch.",
      "enum": [
        "ecos",
        "kosis",
        "oecd",
        "other_official"
      ],
      "title": "SourceSystem",
      "type": "string"
    },
    "ThirdPartyStatus": {
      "description": "Whether the portal publisher is also the original statistical producer.",
      "enum": [
        "first_party",
        "third_party",
        "unknown"
      ],
      "title": "ThirdPartyStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "An auditable ruling for one exact publisher table/item scope.",
  "properties": {
    "approval_record_reference": {
      "anyOf": [
        {
          "pattern": "^docs/decisions/[0-9]{4}-[a-z0-9-]+\\.md#approval-record$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Record Reference"
    },
    "approval_recorded_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Recorded At"
    },
    "approved_by": {
      "anyOf": [
        {
          "maxLength": 10000,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved By"
    },
    "attribution": {
      "anyOf": [
        {
          "$ref": "#/$defs/AttributionRequirement"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "content_class": {
      "$ref": "#/$defs/ContentClass"
    },
    "decision_basis": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Decision Basis",
      "type": "string"
    },
    "decision_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._-]*[a-z0-9]$",
      "title": "Decision Id",
      "type": "string"
    },
    "decision_state": {
      "$ref": "#/$defs/RedistributionStatus"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/RightsEvidence"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "frequency": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Frequency",
      "type": "string"
    },
    "intended_operations": {
      "items": {
        "$ref": "#/$defs/RightsOperation"
      },
      "minItems": 1,
      "title": "Intended Operations",
      "type": "array"
    },
    "item_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._@:/-]*$",
      "title": "Item Id",
      "type": "string"
    },
    "item_title": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Item Title",
      "type": "string"
    },
    "kosis_content_category": {
      "anyOf": [
        {
          "$ref": "#/$defs/KosisContentCategory"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "operation_rules": {
      "items": {
        "$ref": "#/$defs/OperationRule"
      },
      "minItems": 1,
      "title": "Operation Rules",
      "type": "array"
    },
    "original_producer": {
      "anyOf": [
        {
          "maxLength": 10000,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Original Producer"
    },
    "producer_mapping_basis": {
      "$ref": "#/$defs/ProducerMappingBasis"
    },
    "producer_mapping_title": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Producer Mapping Title",
      "type": "string"
    },
    "publisher": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Publisher",
      "type": "string"
    },
    "rights_instrument_accessed_on": {
      "format": "date",
      "title": "Rights Instrument Accessed On",
      "type": "string"
    },
    "rights_instrument_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._-]*[a-z0-9]$",
      "title": "Rights Instrument Id",
      "type": "string"
    },
    "rights_instrument_url": {
      "format": "uri",
      "minLength": 1,
      "title": "Rights Instrument Url",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_system": {
      "$ref": "#/$defs/SourceSystem"
    },
    "table_id": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._@:/-]*$",
      "title": "Table Id",
      "type": "string"
    },
    "table_title": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Table Title",
      "type": "string"
    },
    "third_party_status": {
      "$ref": "#/$defs/ThirdPartyStatus"
    },
    "unit": {
      "maxLength": 10000,
      "minLength": 1,
      "title": "Unit",
      "type": "string"
    },
    "valid_until": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Valid Until"
    }
  },
  "required": [
    "decision_id",
    "publisher",
    "source_system",
    "table_id",
    "item_id",
    "table_title",
    "item_title",
    "producer_mapping_title",
    "frequency",
    "unit",
    "content_class",
    "producer_mapping_basis",
    "evidence",
    "rights_instrument_id",
    "rights_instrument_url",
    "rights_instrument_accessed_on",
    "third_party_status",
    "operation_rules",
    "intended_operations",
    "decision_state",
    "decision_basis"
  ],
  "title": "SeriesRightsDecision",
  "type": "object"
}
